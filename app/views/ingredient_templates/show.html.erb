<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">Ingredient #<%= @the_ingredient.id %> Details</h1>
  <div>
    <%= link_to "Go Back", ingredients_path, class: "btn btn-outline-secondary btn-sm" %>
    <%= button_to "Delete Ingredient", ingredient_path(@the_ingredient), method: :delete, class: "btn btn-outline-danger btn-sm", data: { turbo_confirm: "Delete This Ingredient?" } %>
  </div>
</div>

<div class="row">
  <div class="col-lg-6">
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-white">
        <h2 class="h6 mb-0">Details</h2>
      </div>
      <div class="card-body">
        <dl class="row mb-0">
          <dt class="col-sm-4 text-muted">Recipe</dt>
          <dd class="col-sm-8"><%= @the_ingredient.recipe_id %></dd>
          <dt class="col-sm-4 text-muted">Unit</dt>
          <dd class="col-sm-8"><%= @the_ingredient.unit %></dd>
          <dt class="col-sm-4 text-muted">Amount</dt>
          <dd class="col-sm-8"><%= @the_ingredient.amount %></dd>
          <dt class="col-sm-4 text-muted">Name</dt>
          <dd class="col-sm-8"><%= @the_ingredient.name %></dd>
          <dt class="col-sm-4 text-muted">Created</dt>
          <dd class="col-sm-8"><%= time_ago_in_words(@the_ingredient.created_at) %> ago</dd>
          <dt class="col-sm-4 text-muted">Updated</dt>
          <dd class="col-sm-8"><%= time_ago_in_words(@the_ingredient.updated_at) %> ago</dd>
        </dl>
      </div>
    </div>
  </div>
  <div class="col-lg-6">
    <div class="card shadow-sm">
      <div class="card-header bg-white">
        <h2 class="h6 mb-0">Edit Ingredient</h2>
      </div>
      <div class="card-body">
        <%= form_with model: @the_ingredient, url: ingredient_path(@the_ingredient), method: :patch do |f| %>
          <div class="mb-3">
            <%= f.label :recipe_id, "Recipe", class: "form-label" %>
            <%= f.number_field :recipe_id, class: "form-control", required: true %>
          </div>
          <div class="mb-3">
            <%= f.label :unit, "Unit", class: "form-label" %>
            <%= f.text_field :unit, class: "form-control", required: true, maxlength: 255 %>
          </div>
          <div class="mb-3">
            <%= f.label :amount, "Amount", class: "form-label" %>
            <%= f.text_field :amount, class: "form-control", required: true, maxlength: 255 %>
          </div>
          <div class="mb-3">
            <%= f.label :name, "Name", class: "form-label" %>
            <%= f.text_field :name, class: "form-control", required: true, maxlength: 255 %>
          </div>
          <%= f.submit "Update Ingredient", class: "btn btn-primary" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
