<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Recipe Manager" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>

    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <!-- Bootstrap 5 CSS (CDN) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    <%= javascript_importmap_tags %>
    <style>
      :root { --bs-primary: #6f42c1; --bs-primary-rgb: 111, 66, 193; --app-bg: #f5f3f8; --card-radius: 0.75rem; --navbar-shadow: 0 2px 16px rgba(111, 66, 193, 0.14); }
      body { font-family: "Plus Jakarta Sans", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background-color: #f5f3f8 !important; }
      .navbar { box-shadow: var(--navbar-shadow); }
      .navbar-brand { font-weight: 700; letter-spacing: -0.02em; }
      .navbar.bg-primary, .bg-primary { background-color:rgb(135, 95, 210) !important; }
      .navbar-nav form.d-inline { display: inline; margin: 0; }
      .navbar-nav form.d-inline .nav-link { display: inline-block; font-weight: inherit; }
      .card { border-radius: var(--card-radius); border: none; box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
      .card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
      .btn { border-radius: 0.5rem; font-weight: 500; }
      .btn-lg { border-radius: 0.6rem; }
      .btn-primary { background-color: #6f42c1 !important; border-color: #6f42c1 !important; }
      .btn-primary:hover { background-color: #5a32a3 !important; border-color: #522d94 !important; }
      .btn-outline-primary { color: #59359c !important; border-color: #6f42c1 !important; }
      .btn-outline-primary:hover { background-color: #6f42c1 !important; color: #fff !important; }
      .btn-outline-light-purple { color: #6f42c1 !important; border: 1px solid rgba(111, 66, 193, 0.5) !important; background-color: rgba(111, 66, 193, 0.08) !important; }
      .btn-outline-light-purple:hover { background-color: rgba(111, 66, 193, 0.15) !important; color: #5a32a3 !important; border-color: #a790d2 !important; }
      .text-primary { color: #6f42c1 !important; }
      .link-primary { color: #6f42c1 !important; }
      .link-primary:hover { color: #5a32a3 !important; }
      .bg-primary.bg-opacity-10 { background-color: rgba(111, 66, 193, 0.1) !important; }
      .form-control:focus, .form-select:focus { border-color: rgba(111, 66, 193, 0.5); box-shadow: 0 0 0 0.25rem rgba(111, 66, 193, 0.25); }
      .form-check-input:checked { background-color: #6f42c1; border-color: #6f42c1; }
      .form-check-input:focus { border-color: rgba(111, 66, 193, 0.5); box-shadow: 0 0 0 0.25rem rgba(111, 66, 193, 0.25); }
      .breadcrumb a { color: #6f42c1; }
      .breadcrumb a:hover { color: #5a32a3; }
      .search-form-max { max-width: 24rem; }
      .card-max-sm { max-width: 32rem; }
      .card.bg-light-lilac { background-color: #f0edf4 !important; }
      img.recipe-image-wrap { max-height: 400px; object-fit: contain; background: #dfd1f4; }
      .pagination .page-link { color: #6f42c1; }
      .pagination .page-item.active .page-link { background-color: #6f42c1; border-color: #6f42c1; }
      .pagination .page-link:hover { color: #5a32a3; }
    </style>
  </head>

  <body class="bg-light min-vh-100">
    <%= render "shared/navbar" %>

    <main class="container app-main pt-4 pt-md-5 pb-5">
      <%= render "shared/flash" %>
      <%= render "shared/breadcrumbs" %>

      <%= yield %>
    </main>

    <!-- Bootstrap 5 JS (for alert dismiss, etc.) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", function () {
          navigator.serviceWorker.register("/service-worker.js").catch(function () {});
        });
      }
    </script>
  </body>
</html>
