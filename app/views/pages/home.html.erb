<% content_for :head do %>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous">
<% end %>

<div class="landing-page">
  <!-- Hero: Value proposition + CTA -->
  <section class="landing-hero text-center">
    <h1 class="display-4 fw-bold text-primary mb-3">Recipe Manager</h1>
    <p class="lead text-dark mx-auto mb-4 landing-hero-lead">
      Turn a photo of any recipe into a structured, searchable collection. We extract the title, ingredients with units, and steps—so you can stop retyping and start cooking.
    </p>
    <p class="text-muted mb-4">Save Time. Reduce clutter. Keep Your Recipes in One Place.</p>
    <div class="d-flex gap-2 justify-content-center flex-wrap">
      <%= link_to "Get Started — Sign Up!", new_user_registration_path, class: "btn btn-primary btn-lg px-4" %>
      <%= link_to "Sign In", new_user_session_path, class: "btn btn-outline-primary btn-lg" %>
    </div>
  </section>

  <!-- Target Audience -->
  <section class="landing-section border-top bg-white">
    <div class="container">
      <h2 class="h4 text-center text-primary mb-4">Built For</h2>
      <div class="row g-3 justify-content-center text-center">
        <div class="col-md-4">
          <div class="p-3 rounded bg-light">
            <i class="bi bi-person-hearts text-primary fs-2"></i>
            <p class="mb-0 mt-2 small fw-semibold">Home Cooks</p>
            <p class="mb-0 small text-muted">Who want to digitize their recipes while saving time in the kitchen.</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="p-3 rounded bg-light">
            <i class="bi bi-journal-bookmark text-primary fs-2"></i>
            <p class="mb-0 mt-2 small fw-semibold">Recipe Collectors</p>
            <p class="mb-0 small text-muted">Who need an easy way to store, find, and organize their recipes.</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="p-3 rounded bg-light">
            <i class="bi bi-clock-history text-primary fs-2"></i>
            <p class="mb-0 mt-2 small fw-semibold">Anyone Wanting to Save Time </p>
            <p class="mb-0 small text-muted">On scrolling and searching, and want to spend more time cooking!</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works / Features and Benefits -->
  <section class="landing-section border-top">
    <div class="container">
      <h2 class="h4 text-center text-primary mb-4">How it Works</h2>
      <div class="row g-4">
        <div class="col-md-4">
          <div class="card landing-feature-card shadow-sm h-100">
            <div class="card-body text-center p-4">
              <span class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width: 4rem; height: 4rem;">
                <i class="bi bi-camera-fill text-primary fs-3"></i>
              </span>
              <h3 class="h6 fw-bold">1. Upload a Photo</h3>
              <p class="small text-muted mb-0">Take a picture of a recipe (presaved, handwritten, or digital) or choose a screenshot. We accept common image formats.</p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card landing-feature-card shadow-sm h-100">
            <div class="card-body text-center p-4">
              <span class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width: 4rem; height: 4rem;">
                <i class="bi bi-cpu text-primary fs-3"></i>
              </span>
              <h3 class="h6 fw-bold">2. We Parse It</h3>
              <p class="small text-muted mb-0">Our system extracts the recipe title, ingredients (with quantities and preferred units), and step-by-step instructions automatically.</p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card landing-feature-card shadow-sm h-100">
            <div class="card-body text-center p-4">
              <span class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width: 4rem; height: 4rem;">
                <i class="bi bi-folder-check text-primary fs-3"></i>
              </span>
              <h3 class="h6 fw-bold">3. Save and Use</h3>
              <p class="small text-muted mb-0">Recipes are stored in your account, making it easy to upload and store- so you can get back to cooking!</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="landing-cta-section border-top bg-primary bg-opacity-10 text-center">
    <div class="container">
      <h2 class="h4 text-primary mb-2">Ready to Organize your Recipes?</h2>
      <p class="text-muted mb-4">Create a Free Account and Upload your First Recipe in Seconds.</p>
      <%= link_to "Sign Up — Today!", new_user_registration_path, class: "btn btn-primary btn-lg px-4" %>
    </div>
  </section>
</div>
