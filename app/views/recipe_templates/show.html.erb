<% content_for :title, @the_recipe.title %>
<% content_for :head do %>
  <%= tag.meta name: "description", content: "#{@the_recipe.title} — Recipe with #{@the_recipe.recipe_ingredients.size} ingredients and #{@the_recipe.steps.size} steps." %>
  <%= tag.meta property: "og:title", content: @the_recipe.title %>
  <%= tag.meta property: "og:description", content: "#{@the_recipe.title} — Recipe with #{@the_recipe.recipe_ingredients.size} ingredients and #{@the_recipe.steps.size} steps." %>
  <%= tag.meta property: "og:type", content: "website" %>
  <style>
    .edit-recipe-toggle { cursor: pointer; }
    .edit-recipe-toggle .chevron { display: inline-block; transition: transform 0.2s ease; }
    .edit-recipe-toggle[aria-expanded="true"] .chevron { transform: rotate(180deg); }
  </style>
<% end %>

<div class="d-flex justify-content-between align-items-center mb-4" data-controller="recipe-channel" data-recipe-channel-recipe-id-value="<%= @the_recipe.id %>">
  <h1 class="h3 mb-0" id="recipe_title_display"><%= @the_recipe.title %></h1>
  <div class="d-flex flex-wrap gap-2">
    <%= link_to "Back to List", recipes_path, class: "btn btn-outline-secondary btn-sm" %>
    <% if policy(@the_recipe).destroy? %>
      <%= button_to "Delete Recipe", recipe_path(@the_recipe), method: :delete, form: { class: "d-inline mb-0" }, class: "btn btn-outline-danger btn-sm", data: { turbo_confirm: "Delete this Recipe?" } %>
    <% end %>
  </div>
</div>

<div class="row">
  <div class="col-lg-8">
    <% if @the_recipe.original_image.attached? %>
      <div class="card shadow-sm mb-4">
        <%= image_tag @the_recipe.original_image, class: "card-img-top recipe-image-wrap", alt: @the_recipe.title.presence || "Recipe Image" %>
        <% if @can_reparse_recipe %>
          <div class="card-body py-2">
            <%= button_to "Re-Parse from Image", parse_recipe_path(@the_recipe), method: :post, class: "btn btn-sm btn-outline-primary", form: { data: { turbo_confirm: "Re-Parse this Recipe from the Image?" } } %>
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="card shadow-sm mb-4">
      <div class="card-body">
        <dl class="row mb-0">
          <dt class="col-sm-3 text-muted">Title</dt>
          <dd class="col-sm-9"><%= @the_recipe.title %></dd>
          <dt class="col-sm-3 text-muted">User</dt>
          <dd class="col-sm-9"><%= @the_recipe.author.display_name %></dd>
          <dt class="col-sm-3 text-muted" id="recipe_source_dt"<%= raw(' style="display:none"') if @the_recipe.source_url.blank? %>>Source</dt>
          <dd class="col-sm-9" id="recipe_source_dd"<%= raw(' style="display:none"') if @the_recipe.source_url.blank? %>>
            <% if @the_recipe.source_url.present? %>
              <%= link_to @the_recipe.source_url, @the_recipe.source_url, id: "recipe_source_display", target: "_blank", rel: "noopener" %>
            <% else %>
              <a id="recipe_source_display" href="#" style="display: none;"></a>
            <% end %>
          </dd>
        </dl>
      </div>
    </div>

    <%= render "recipe_templates/ingredients", recipe: @the_recipe %>

    <%= render "recipe_templates/steps", recipe: @the_recipe %>

    <%= render "recipe_templates/comments", commentable: @the_recipe, comments: @the_recipe.comments.includes(:user).order(created_at: :asc) %>
  </div>

  <div class="col-lg-4">
    <% if policy(@the_recipe).update? %>
    <div class="card shadow-sm sticky-top mb-4" style="top: 1rem;" data-controller="collapse-close">
      <div class="card-header bg-white edit-recipe-toggle d-flex justify-content-between align-items-center py-2" data-bs-toggle="collapse" data-bs-target="#editRecipeCollapse" role="button" aria-expanded="false" aria-controls="editRecipeCollapse">
        <h2 class="h6 mb-0">Edit Recipe</h2>
        <span class="chevron text-muted small" aria-hidden="true">&#9660;</span>
      </div>
      <div class="collapse" id="editRecipeCollapse" data-collapse-close-target="collapse">
      <div class="card-body" data-controller="nested-form">
        <%= form_with model: @the_recipe, url: recipe_path(@the_recipe), method: :patch do |f| %>
          <div class="mb-3">
            <%= f.label :title, "Title", class: "form-label" %>
            <%= f.text_field :title, id: "title_box", class: "form-control", required: true, maxlength: 255 %>
          </div>
          <div class="mb-3">
            <%= f.label :source_url, "Recipe URL", class: "form-label" %>
            <%= f.url_field :source_url, id: "source_url_box", class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= f.label :recipe_ingredients, "Ingredients", class: "form-label" %>
            <div data-nested-form-target="ingredientContainer">
              <%= f.fields_for :recipe_ingredients do |ing_f| %>
                <%= render "recipe_templates/ingredient_fields", f: ing_f %>
              <% end %>
            </div>
            <button type="button" class="btn btn-outline-secondary btn-sm mt-1" data-action="click->nested-form#addIngredient">+ Add Ingredient</button>
            <template data-nested-form-target="ingredientTemplate">
              <%= f.fields_for :recipe_ingredients, Ingredient.new, child_index: "NEW_INGREDIENT_INDEX" do |ing_f| %>
                <%= render "recipe_templates/ingredient_fields", f: ing_f %>
              <% end %>
            </template>
          </div>

          <div class="mb-3">
            <%= f.label :steps, "Steps", class: "form-label" %>
            <div data-nested-form-target="stepContainer">
              <%= f.fields_for :steps do |step_f| %>
                <%= render "recipe_templates/step_fields", f: step_f %>
              <% end %>
            </div>
            <button type="button" class="btn btn-outline-secondary btn-sm mt-1" data-action="click->nested-form#addStep">+ Add Step</button>
            <template data-nested-form-target="stepTemplate">
              <%= f.fields_for :steps, Step.new, child_index: "NEW_STEP_INDEX" do |step_f| %>
                <%= render "recipe_templates/step_fields", f: step_f %>
              <% end %>
            </template>
          </div>

          <%= f.submit "Update Recipe", class: "btn btn-primary w-100" %>
          <button type="button" class="btn btn-link btn-sm w-100 mt-2 text-muted text-decoration-none" data-action="click->collapse-close#close">&#9650; Close</button>
        <% end %>
      </div>
      </div>
    </div>
    <% end %>
  </div>
</div>
