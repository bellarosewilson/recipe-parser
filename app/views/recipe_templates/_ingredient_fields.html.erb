<div class="nested-fields row g-2 align-items-center mb-2" data-nested-form-target="ingredientRow">
  <%= f.hidden_field :id if f.object.persisted? %>
  <div class="col">
    <%= f.text_field :name, class: "form-control form-control-sm", placeholder: "Ingredient Name" %>
  </div>
  <div class="col">
    <%= f.text_field :amount, class: "form-control form-control-sm", placeholder: "Amount" %>
  </div>
  <div class="col">
    <%= f.text_field :unit, class: "form-control form-control-sm", placeholder: "Unit" %>
  </div>
  <div class="col-auto">
    <%= f.check_box :_destroy, class: "form-check-input" %>
    <%= f.label :_destroy, "Remove", class: "form-check-label small text-muted" %>
  </div>
</div>
