<h1 class="mb-4">List of All Steps</h1>

<div class="card shadow-sm mb-4">
  <div class="card-body">
    <h2 class="h5 mb-3">Add a New Step</h2>
    <%= form_with url: steps_path, scope: :step do |f| %>
      <div class="row g-3">
        <div class="col-md-4">
          <%= f.label :recipe_id, "Recipe", class: "form-label" %>
          <%= f.number_field :recipe_id, class: "form-control" %>
        </div>
        <div class="col-md-4">
          <%= f.label :position, "Position", class: "form-label" %>
          <%= f.text_field :position, class: "form-control" %>
        </div>
        <div class="col-md-4">
          <%= f.label :instruction, "Instruction", class: "form-label" %>
          <%= f.text_field :instruction, class: "form-control" %>
        </div>
      </div>
      <div class="mt-3">
        <%= f.submit "Create Step", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>

<div class="card shadow-sm">
  <div class="card-header bg-white">
    <h2 class="h6 mb-0">Your Steps</h2>
  </div>
  <ul class="list-group list-group-flush">
    <% @list_of_steps.each do |a_step| %>
      <li class="list-group-item d-flex justify-content-between align-items-center">
        <span>Step #<%= a_step.id %></span>
        <%= link_to "View", step_path(a_step), class: "btn btn-outline-primary btn-sm" %>
      </li>
    <% end %>
  </ul>
</div>
